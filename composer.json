{
    "name": "mindtwo/laravel-auto-create-uuid",
    "description": "Automatically generate UUIDs for Eloquent models on creation and replication.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "eloquent",
        "uuid",
        "trait",
        "model"
    ],
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de",
            "homepage": "https://www.mindtwo.de/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^8.0 || ^9.5 || ^10.0 || ^11.0",
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "mindtwo\\LaravelAutoCreateUuid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mindtwo\\LaravelAutoCreateUuid\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
